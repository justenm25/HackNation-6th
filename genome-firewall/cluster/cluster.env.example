# Genome Firewall cluster configuration.
#
# Copy to cluster.env and fill in every REQUIRED value for your site. Nothing here is
# guessed for you: partition names, time limits, and module names differ per cluster, and
# a wrong value fails at submit time rather than silently doing something unintended.
#
#   cp cluster.env.example cluster.env
#   ${EDITOR:-vi} cluster.env
#
# cluster.env is sourced by submit.sh and exported into both jobs.

# ---------------------------------------------------------------- Slurm accounting
# REQUIRED. Ask your cluster documentation or `sinfo -s` for valid partitions.
GF_PARTITION=
# Optional. Leave empty if your site does not require an account or QOS.
GF_ACCOUNT=
GF_QOS=

# ---------------------------------------------------------------- AMRFinder array job
# Walltime per array task, not for the whole array. One genome takes roughly a minute on
# a warm filesystem; the default leaves generous headroom for cold cache and retries.
GF_AMR_TIME=00:30:00
GF_AMR_MEM=8G
GF_AMR_CPUS=2
# Concurrently running array tasks. Keep this within what your partition and the shared
# filesystem tolerate; AMRFinder is I/O heavy on database reads.
GF_AMR_ARRAY_THROTTLE=50
# Array size. Leave empty to derive it from the cohort CSV (recommended), or set an
# explicit count to submit only the first N genomes for a pilot run.
GF_AMR_ARRAY_SIZE=

# ---------------------------------------------------------------- Aggregation job
# Runs mash grouping and dataset assembly after the array finishes. Mash sketching holds
# the full cohort in memory, so this needs more memory than a single AMRFinder task.
GF_ASSEMBLE_TIME=04:00:00
GF_ASSEMBLE_MEM=32G
GF_ASSEMBLE_CPUS=8

# ---------------------------------------------------------------- Environment
# REQUIRED. Absolute path to the conda/mamba environment holding amrfinder, mash, and the
# Python dependencies. This is the environment prefix, not the python binary.
GF_ENV_PREFIX=
# REQUIRED only if your site exposes conda through modules rather than a shell hook.
# Set to the module name your cluster uses; leave empty to rely on `conda activate` being
# available. Do not guess — check your cluster's module listing with `module avail`.
GF_CONDA_MODULE=
# Optional extra modules, space separated, loaded before the environment is activated.
GF_EXTRA_MODULES=

# ---------------------------------------------------------------- Data layout
# REQUIRED. Absolute paths on the cluster filesystem. Use scratch or project storage with
# room for the AMRFinder TSVs and mash sketches, not your home directory quota.
GF_REPO_ROOT=
GF_COHORT_CSV=
GF_FASTA_ROOT=
GF_WORK_ROOT=

# ---------------------------------------------------------------- Analysis parameters
# Must match the organism the cohort was collected for; see `amrfinder --list_organisms`.
GF_ORGANISM=Escherichia
# Optional AMRFinder database directory. Leave empty to use the environment's default.
GF_AMRFINDER_DB=
GF_MASH_DISTANCE=0.001
GF_MASH_KMER=21
GF_MASH_SKETCH=10000
GF_SPLIT_TRIALS=250
GF_SEED=42
GF_SCHEMA_VERSION=gf-amr-v1
